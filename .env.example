# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=fab
POSTGRES_PASSWORD=fab
POSTGRES_DB=fabgreat
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Assembled by the API; override if your setup differs
DATABASE_URL=postgresql+asyncpg://fab:fab@localhost:5432/fabgreat
DATABASE_SSL=false

# ── pgAdmin (optional, start with: docker compose --profile tools up) ─────────
PGADMIN_EMAIL=admin@fab.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Card dataset (the-fab-cube/flesh-and-blood-cards release tag) ─────────────
CARDS_DATA_VERSION=v8.1.0

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
